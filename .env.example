# --- Telegram ---
BOT_TOKEN=your_telegram_bot_token

# Comma-separated Telegram IDs. Every listed ID gets admin commands and
# DM-relay forwards. Get yours from @userinfobot.
# Single-admin setups can use ADMIN_ID=... instead — both names work.
ADMIN_IDS=123456789

CHANNEL_ID=-1001234567890
CHANNEL_INVITE_LINK=https://t.me/+your_channel_invite_link

# --- Exness Partnership API ---
EXNESS_BASE_URL=https://my.exnessaffiliates.com
EXNESS_LOGIN=partner@example.com
EXNESS_PASSWORD=your_partner_password
# Use the direct sign-up redirect, not the bare /a/<code> link — the latter
# sometimes lands on a generic landing page instead of the registration form.
EXNESS_REFERRAL_LINK=https://one.exnessonelink.com/boarding/sign-up/a/your_partner_code
# Shown to users who already have an Exness account, so they can ask Exness
# support to switch their partner code to ours. Recommended to fill in.
EXNESS_PARTNER_CODE=your_partner_code

# Deep links shown to users who are already under our partner but still
# need to activate (deposit ≥ MIN_DEPOSIT_USD or first trade). Defaults
# point to the standard Exness PA — override only if you know better.
EXNESS_DEPOSIT_URL=https://my.exness.com/pa/payments-and-wallet/deposit
EXNESS_PA_URL=https://my.exness.com/pa/

# --- Bot logic tuning ---
# Activation requires the client to have made a first deposit AND to be in
# a deposit "tier" at or above this threshold. Exness only reports deposits
# as a coarse range-ID, NOT an exact dollar figure:
#   1: $0-10   2: $10-50   3: $50-250   4: $250-1000   5: $1000-5000   6: >$5000
# So MIN_DEPOSIT_USD maps to: 0→tier 1+ (any deposit), 10→tier 2+,
# 50→tier 3+, 250→tier 4+, 1000→tier 5+, >1000→tier 6.
# Set MIN_DEPOSIT_USD=0 if "any deposit at all" is enough.
MIN_DEPOSIT_USD=50
# Set this to true to ALSO require the user to have placed a first trade.
ACTIVATION_REQUIRE_TRADE=false
INACTIVITY_WARN_DAYS=11
INACTIVITY_KICK_DAYS=14
RECHECK_INTERVAL_HOURS=6
PENDING_POLL_MINUTES=5

# After this many hours in 'pending' with no activation, the scheduler
# stops auto-checking that user — they can resume by tapping
# "Re-check now" in the bot or sending /start. Resets on every manual
# re-check, so an active user is never cut off mid-flow.
PENDING_AUTO_GIVEUP_HOURS=24

WARNING_GRACE_DAYS=3

# Optional UX strings
BRAND_NAME=VIP Signals

# --- Storage / runtime ---
DATABASE_URL=sqlite://data/db.sqlite3
TEST_MODE=false

# Display TZ for admin output (IANA name). Internal storage is UTC.
DISPLAY_TZ=UTC
